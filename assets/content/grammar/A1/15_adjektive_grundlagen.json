                                        "type":  "rules",
                                        "title":  "Merke dir!",
                                        "items":  [
                                                      "After sein, werden, bleiben → NO ending: Das Haus ist groß.",
                                                      "Before a noun → ALWAYS an ending: ein großES Haus.",
                                                      "After der/die/das → mostly -e or -en.",
                                                      "After ein → adjective shows the gender: ein großER Mann, ein großES Kind."
                                                  ]
