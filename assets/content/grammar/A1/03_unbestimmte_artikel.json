                                    {
                                        "type":  "concept",
                                        "title":  "Unbestimmte Artikel · Indefinite Articles",
                                        "text":  "We use the indefinite article (a/an) when we talk about something for the first time, when the specific item is not yet known, or when it doesn\u0027t matter which one it is.",
                                        "bullets":  [
                                                        "ein → masculine (ein Tisch, ein Hund)",
                                                        "eine → feminine (eine Lampe, eine Frau)",
                                                        "ein → neuter (ein Buch, ein Kind)",
                                                        "(-) → NO indefinite article in Plural!"
                                                    ]
                                    },
