                                        "type":  "examples",
                                        "title":  "Direkte → Indirekte Rede",
                                        "color":  "teal",
                                        "items":  [
                                                      {
                                                          "de":  "Direkt: \"Ich komme morgen.\"",
                                                          "en":  "Direct: \"I\u0027m coming tomorrow.\""
                                                      },
                                                      {
                                                          "de":  "Indirekt: Er sagt, er komme morgen.",
                                                          "en":  "Indirect: He says (that) he\u0027s coming tomorrow."
                                                      },
                                                      {
                                                          "de":  "Direkt: \"Ich habe keine Zeit.\"",
                                                          "en":  "Direct: \"I have no time.\""
                                                      },
                                                      {
                                                          "de":  "Indirekt: Sie sagt, sie habe keine Zeit.",
                                                          "en":  "Indirect: She says she has no time."
                                                      }
