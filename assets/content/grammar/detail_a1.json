  "g15": {
    "id": "g15",
    "subtitle": "Adjektive · Grundlagen",
    "emoji": "🎨",
    "gradient": [
      "#6366F1",
      "#8B5CF6"
    ],
    "levelBg": "#DCFCE7",
    "levelText": "#16A34A",
    "sections": [
      {
        "type": "concept",
        "title": "Prädikative vs. Attributive Adjektive",
        "text": "Adjectives after sein/werden (predicate) have NO ending. Adjectives placed BEFORE a noun (attributive) must take an ending matching gender, case, and article.",
        "bullets": [
          "Prädikativ: Das Auto ist schnell. (no ending)",
          "Attributiv: Das schnellE Auto fährt. (with ending)"
        ]
      },
      {
        "type": "examples",
        "title": "Prädikative Adjektive (kein Endung)",
        "color": "indigo",
        "items": [
          {
            "de": "Das Buch ist interessant.",
            "en": "The book is interesting."
          },
          {
            "de": "Der Film war gut.",
            "en": "The film was good."
          },
          {
            "de": "Die Blumen sind schön.",
            "en": "The flowers are beautiful."
          }
        ]
      },
      {
        "type": "comparison",
        "title": "Adjektivendungen nach bestimmtem Artikel",
        "headers": [
          "Kasus",
          "Maskulin",
          "Feminin",
          "Neutrum"
        ],
        "rows": [
          [
            "Nominativ",
            "der alt-e Mann",
            "die alt-e Frau",
            "das alt-e Kind"
          ],
          [
            "Akkusativ",
            "den alt-en Mann",
            "die alt-e Frau",
            "das alt-e Kind"
          ]
        ]
      },
      {
        "type": "examples",
        "title": "Attributive Adjektive",
        "color": "violet",
        "items": [
          {
            "de": "Der große Mann arbeitet hier.",
            "en": "The tall man works here."
          },
          {
            "de": "Ich lese ein interessantes Buch.",
            "en": "I'm reading an interesting book."
          },
          {
            "de": "Sie hat eine neue Tasche.",
            "en": "She has a new bag."
          }
        ]
      },
      {
        "type": "rules",
        "title": "Merke dir!",
        "items": [
          "After sein, werden, bleiben → NO ending: Das Haus ist groß.",
          "Before a noun → ALWAYS an ending: ein großES Haus.",
          "After der/die/das → mostly -e or -en.",
          "After ein → adjective shows the gender: ein großER Mann, ein großES Kind."
        ]
      }
    ]
  },
  "g37": {
    "id": "g37",
    "subtitle": "Artikel · Plural",
    "emoji": "📘",
    "gradient": [
      "#3B82F6",
      "#4F46E5"
    ],
    "levelBg": "#DCFCE7",
    "levelText": "#16A34A",
    "sections": [
      {
        "type": "concept",
        "title": "Pluralbildung · Forming Plurals",
        "text": "German nouns form their plurals in several ways. Unfortunately there are no universal rules — you must learn each noun's plural form.",
        "bullets": [
          "-e / -¨e: der Tag → die Tage, der Stuhl → die Stühle",
          "-er / -¨er: das Kind → die Kinder, der Mann → die Männer",
          "-(e)n: die Frau → die Frauen, der Student → die Studenten",
          "-s: das Auto → die Autos",
          "no change or umlaut: der Vater → die Väter"
        ]
      },
      {
        "type": "conjugation",
        "title": "Pluraltypen",
        "color": "blue",
        "rows": [
          {
            "left": "-e / -¨e",
            "right": "der Tag → die Tage"
          },
          {
            "left": "-er / -¨er",
            "right": "das Kind → die Kinder"
          },
          {
            "left": "-(e)n",
            "right": "die Frau → die Frauen"
          },
          {
            "left": "-s",
            "right": "das Auto → die Autos"
          },
          {
            "left": "-¨ / –",
            "right": "der Vater → die Väter"
          }
        ]
      },
      {
        "type": "examples",
        "title": "Beispiele",
        "color": "blue",
        "items": [
          {
            "de": "der Mann → die Männer",
            "en": "the man → the men"
          },
          {
            "de": "das Buch → die Bücher",
            "en": "the book → the books"
          },
          {
            "de": "die Schule → die Schulen",
            "en": "the school → the schools"
          },
          {
            "de": "das Auto → die Autos",
            "en": "the car → the cars"
          }
        ]
      },
      {
        "type": "tip",
        "text": "All plurals use 'die' as their article. In the Dative plural, all nouns add -n unless the plural already ends in -n or -s.",
        "variant": "info"
      },
      {
        "type": "rules",
        "title": "Merke dir!",
        "items": [
          "Always learn the plural with the noun: die Nacht, die Nächte.",
          "Feminine nouns in -e: usually add -n → die Lampe → die Lampen.",
          "Nouns from English/French: usually -s → das Café → die Cafés.",
          "Dative plural: always add -n: den Männern, den Kindern."
        ]
      }
    ]
  },
  "g38": {
